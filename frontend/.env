# ─── API Base URL ────────────────────────────────────────────────────────────
# This is the ONLY value you need to change when switching environments.
#
# LOCAL (your machine):
#   Set to your Cloudflare tunnel URL, e.g.:
#   VITE_API_BASE_URL=https://your-tunnel.trycloudflare.com/api/v1
#
# PRODUCTION (Netlify / Vercel / any host):
#   Do NOT set it here — set VITE_API_BASE_URL in your hosting dashboard
#   under Environment Variables instead. That way you never push code for it.
#
# ─────────────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=https://portraits-prostores-past-massachusetts.trycloudflare.com/api/v1
