# ============================================================
# Streamora Backend — copy this file to .env and fill in values
# ============================================================

NODE_ENV=development
PORT=8000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/streamora?retryWrites=true&w=majority

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET=your_access_token_secret_here
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRY=7d

# Cloudinary — get from cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS — keep as localhost:5173 (Vite proxy handles everything)
CORS_ORIGIN=http://localhost:5173

# Frontend URL for password reset emails
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Email — Gmail SMTP with App Password
# 1. Enable 2FA on Gmail: myaccount.google.com/security
# 2. Generate App Password: myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM=Streamora <your_gmail@gmail.com>
